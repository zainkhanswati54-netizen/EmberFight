/* ===================================================================
   background.js — layered, parallaxing dark-silhouette background.
   Three depth layers (far silhouettes, near silhouettes, ground)
   scroll at different speeds for a subtle sense of depth without
   any colour beyond the warm palette.
=================================================================== */

class Background {
  constructor() {
    this.farOffset = 0;
    this.nearOffset = 0;
    this.groundOffset = 0;
    this.farShapes = this._genSkyline(14, 60, 160);
    this.nearShapes = this._genSkyline(9, 90, 230);
    this.embers = this._genEmbers(18);
  }

  _genSkyline(count, minH, maxH) {
    const shapes = [];
    const segW = PhysicsConfig.WORLD_W / (count - 3);
    for (let i = 0; i < count; i++) {
      shapes.push({
        x: i * segW,
        w: segW * Util.randRange(0.7, 1.1),
        h: Util.randRange(minH, maxH)
      });
    }
    return shapes;
  }

  _genEmbers(count) {
    const list = [];
    for (let i = 0; i < count; i++) {
      list.push({
        x: Util.randRange(0, PhysicsConfig.WORLD_W),
        y: Util.randRange(0, PhysicsConfig.WORLD_H * 0.7),
        r: Util.randRange(0.6, 1.8),
        speed: Util.randRange(6, 16),
        phase: Util.randRange(0, Math.PI * 2),
        baseX: 0
      });
      list[i].baseX = list[i].x;
    }
    return list;
  }

  update(dt, timeS) {
    const w = PhysicsConfig.world;
    this.farOffset = (this.farOffset + w.parallaxFarSpeed * dt) % PhysicsConfig.WORLD_W;
    this.nearOffset = (this.nearOffset + w.parallaxNearSpeed * dt) % PhysicsConfig.WORLD_W;
    this.groundOffset = (this.groundOffset + w.groundScrollSpeed * dt) % 40;

    for (const e of this.embers) {
      e.y -= e.speed * dt;
      e.x = e.baseX + Math.sin(timeS * 0.6 + e.phase) * 8;
      if (e.y < -10) {
        e.y = PhysicsConfig.WORLD_H * 0.75 + Util.randRange(0, 60);
        e.baseX = Util.randRange(0, PhysicsConfig.WORLD_W);
      }
    }
  }

  draw(ctx, theme) {
    const W = PhysicsConfig.WORLD_W;
    const H = PhysicsConfig.WORLD_H;
    const groundY = H - PhysicsConfig.world.groundHeight;

    const sky = ctx.createLinearGradient(0, 0, 0, groundY);
    sky.addColorStop(0, theme.skyTop);
    sky.addColorStop(0.7, theme.skyMid);
    sky.addColorStop(1, theme.skyHorizon);
    ctx.fillStyle = sky;
    ctx.fillRect(0, 0, W, H);

    ctx.save();
    for (const e of this.embers) {
      ctx.globalAlpha = 0.35;
      ctx.fillStyle = theme.emberDust;
      ctx.beginPath();
      ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.restore();

    this._drawSkyline(ctx, this.farShapes, this.farOffset, groundY, theme.silhouetteFar);
    this._drawSkyline(ctx, this.nearShapes, this.nearOffset, groundY, theme.silhouetteNear);

    ctx.fillStyle = theme.ground;
    ctx.fillRect(0, groundY, W, H - groundY);

    ctx.fillStyle = theme.groundRim;
    ctx.fillRect(0, groundY, W, 3);

    ctx.strokeStyle = theme.groundLine;
    ctx.lineWidth = 1;
    ctx.globalAlpha = 0.35;
    for (let x = -this.groundOffset; x < W; x += 40) {
      ctx.beginPath();
      ctx.moveTo(x, groundY + 14);
      ctx.lineTo(x + 18, H);
      ctx.stroke();
    }
    ctx.globalAlpha = 1;
  }

  _drawSkyline(ctx, shapes, offset, groundY, color) {
    ctx.fillStyle = color;
    const W = PhysicsConfig.WORLD_W;
    for (const shift of [0, W]) {
      for (const s of shapes) {
        const x = s.x - offset + shift;
        if (x > W || x + s.w < 0) continue;
        ctx.fillRect(x, groundY - s.h, s.w, s.h);
      }
    }
  }
}
